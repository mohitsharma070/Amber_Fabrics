<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="config" />
          <add segment="database" />
          <add segment="scripts" />
          <add segment="tmp" />
          <add segment="tmp_sessions" />
          <add segment="plugins" />
          <add segment=".git" />
          <add segment="vendor" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".log" allowed="false" />
          <add fileExtension=".sql" allowed="false" />
          <add fileExtension=".sh" allowed="false" />
          <add fileExtension=".phar" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>
    <rewrite>
      <rules>
        <rule name="Force HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^localhost(:[0-9]+)?$" negate="true" />
            <add input="{HTTP_HOST}" pattern="^127\.0\.0\.1(:[0-9]+)?$" negate="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>
        <rule name="Block env variants" stopProcessing="true">
          <match url="^.*\.env(\..*)?$" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Block dotfiles and config internals" stopProcessing="true">
          <match url="(^|/)\.[^/]+|(^|/)(composer\.(json|lock|phar)|\.gitignore|\.gitattributes|phpunit\.xml|README(\.md)?|CHANGELOG\.md|GO_LIVE_CHECKLIST\.md|SECURITY\.md|query)$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Block executable files in public asset folders" stopProcessing="true">
          <match url="^(images|css|js|feeds)/.*\.(php[0-9]?|phtml|phar|cgi|pl|asp|aspx|jsp)$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Block setup and migration scripts" stopProcessing="true">
          <match url="(^|/)(database/setup\.php|database/migrations/.*|tmp-debug-.*\.php|tmp-.*\.php)$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Allow cron runner only" stopProcessing="true">
          <match url="^cron/run-plugins\.php$" ignoreCase="true" />
          <action type="None" />
        </rule>
        <rule name="Block other cron endpoints" stopProcessing="true">
          <match url="^cron/.*" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Front controller fallback" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.php?url={R:1}" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
    </staticContent>
  </system.webServer>
</configuration>
