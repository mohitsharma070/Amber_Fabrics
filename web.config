<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="config" />
          <add segment="database" />
          <add segment="tmp_sessions" />
          <add segment="plugins" />
          <add segment=".git" />
          <add segment="vendor" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".log" allowed="false" />
          <add fileExtension=".sql" allowed="false" />
          <add fileExtension=".sh" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>
    <rewrite>
      <rules>
        <rule name="Block env variants" stopProcessing="true">
          <match url="^.*\.env(\..*)?$" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Block dotfiles and config internals" stopProcessing="true">
          <match url="(^|/)\.[^/]+|(^|/)(composer\.(json|lock)|\.gitignore|\.gitattributes|phpunit\.xml|README(\.md)?)$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Block setup and migration scripts" stopProcessing="true">
          <match url="(^|/)(database/setup\.php|database/migrations/.*|tmp-debug-.*\.php|tmp-.*\.php)$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Allow cron runner only" stopProcessing="true">
          <match url="^cron/run-plugins\.php$" ignoreCase="true" />
          <action type="None" />
        </rule>
        <rule name="Block other cron endpoints" stopProcessing="true">
          <match url="^cron/.*" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Front controller fallback" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.php?url={R:1}" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
