# Application Environment
APP_ENV=local

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fabric_export

# Email Configuration
ADMIN_NOTIFICATION_EMAIL=your-admin-email@example.com
MAIL_FROM=your-from-email@example.com

# SMTP Configuration (for sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=your-gmail-app-password-here

# Razorpay Configuration (Test/Live)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxx

# Instructions:
# 1. Copy this file to .env for production/shared hosting values.
# 2. Create .env.local for local machine overrides.
# 3. Use APP_ENV=local locally and APP_ENV=production on hosting.
# 4. For Gmail: Generate an App Password from Google Account settings.
# 5. For Razorpay test mode: use Dashboard > Settings > API Keys > Test Mode keys.
